{
  "name": "@excalimath/core",
  "version": "1.1.1",
  "description": "Math companion plugin for Excalidraw — equations, graphs, and shape libraries.",
  "license": "MIT",
  "author": "Tamer — ITWorx EdTech",
  "contributors": [
    {
      "name": "DynoW",
      "url": "https://github.com/DynoW"
    }
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@excalidraw/excalidraw": ">=0.17.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "katex": "^0.16.0",
    "mathjs": "^15.1.1",
    "plotly.js-dist-min": "^3.5.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.0",
    "@types/plotly.js-dist-min": "^2.3.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
